<%# app/views/admin/reports/top_products.html.erb %>
<%= link_to "← Natrag", request.referer || root_path,
            class: "inline-block px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-lg font-semibold transition" %>
<h1 class="text-2xl font-bold mb-2">Top proizvodi</h1>
<p class="text-sm text-gray-600 mb-6"><%= @from %> → <%= @to %></p>


<%= render "range_form", url: top_products_admin_reports_path %>

<div class="bg-white border rounded-lg overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50 text-sm text-gray-600">
    <tr>
      <th class="text-left p-3">Proizvod</th>
      <th class="text-left p-3">SKU</th>
      <th class="text-right p-3">Količina</th>
      <th class="text-right p-3">Prihod</th>
    </tr>
    </thead>
    <tbody class="divide-y">
    <% @rows.each do |r| %>
      <tr>
        <td class="p-3 font-semibold"><%= r.name %></td>
        <td class="p-3 font-mono text-sm"><%= r.sku %></td>
        <td class="p-3 text-right"><%= r.qty.to_i %></td>
        <td class="p-3 text-right font-semibold"><%= number_to_currency(r.revenue_cents.to_i / 100.0, unit: "€") %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>