<% btn_primary = "inline-flex items-center gap-2 px-4 py-2 rounded bg-blue-600 hover:bg-blue-700 text-white font-semibold shadow" %>
<% btn_secondary = "inline-flex items-center gap-2 px-3 py-2 rounded bg-gray-100 hover:bg-gray-200 text-gray-900 font-semibold" %>
<% btn_danger = "inline-flex items-center gap-2 px-3 py-2 rounded bg-red-600 hover:bg-red-700 text-white font-semibold shadow" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold">Proizvodi</h1>
    <p class="text-sm text-gray-600 mt-1">Upravljanje katalogom proizvoda (cijene, SKU, aktivnost)</p>
  </div>


  <%= link_to new_admin_product_path, class: btn_primary do %>
    <span class="text-lg leading-none">➕</span>
    Novi proizvod
  <% end %>
</div>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
  <%= form_with url: admin_products_path, method: :get, local: true,
                class: "grid grid-cols-1 md:grid-cols-5 gap-4 items-end" do |f| %>

    <div>
      <%= f.label :query, "Pretraži", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :query,
                       value: params[:query],
                       placeholder: "Naziv ili SKU",
                       class: "w-full rounded-lg border-gray-300" %>
    </div>

    <div>
      <%= f.label :category, "Kategorija", class: "block text-sm font-medium mb-1" %>
      <%= f.select :category,
                   options_for_select(@categories, params[:category]),
                   { include_blank: "Sve kategorije" },
                   class: "w-full rounded-lg border-gray-300" %>
    </div>

    <div>
      <%= f.label :availability, "Status / dostupnost", class: "block text-sm font-medium mb-1" %>
      <%= f.select :availability,
                   options_for_select([
                                        ["Sve", ""],
                                        ["Aktivni", "active"],
                                        ["Neaktivni", "inactive"],
                                        ["Na zalihi", "in_stock"],
                                        ["Nema na zalihi", "out_of_stock"]
                                      ], params[:availability]),
                   {},
                   class: "w-full rounded-lg border-gray-300" %>
    </div>

    <div>
      <%= f.label :sort, "Sortiranje", class: "block text-sm font-medium mb-1" %>
      <%= f.select :sort,
                   options_for_select([
                                        ["Naziv A-Z", "name_asc"],
                                        ["Naziv Z-A", "name_desc"],
                                        ["Cijena uzlazno", "price_asc"],
                                        ["Cijena silazno", "price_desc"],
                                        ["Zaliha uzlazno", "stock_asc"],
                                        ["Zaliha silazno", "stock_desc"]
                                      ], params[:sort]),
                   {},
                   class: "w-full rounded-lg border-gray-300" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit "Primijeni",
                   class: "px-4 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition" %>

      <%= link_to "Reset",
                  admin_products_path,
                  class: "px-4 py-2 bg-gray-200 text-gray-800 font-semibold rounded-lg hover:bg-gray-300 transition" %>
    </div>

  <% end %>
</div>

<div class="bg-white border rounded-lg shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full border-collapse">
      <thead class="bg-gray-50">
      <tr class="border-b">
        <th class="text-left p-3 text-xs font-semibold uppercase tracking-wide text-gray-600">Naziv</th>
        <th class="text-left p-3 text-xs font-semibold uppercase tracking-wide text-gray-600">SKU</th>
        <th class="text-left p-3 text-xs font-semibold uppercase tracking-wide text-gray-600">Cijena</th>
        <th class="text-left p-3 text-xs font-semibold uppercase tracking-wide text-gray-600">Zaliha</th>
        <th class="text-left p-3 text-xs font-semibold uppercase tracking-wide text-gray-600">Status</th>
        <th class="text-right p-3 text-xs font-semibold uppercase tracking-wide text-gray-600">Akcije</th>
      </tr>
      </thead>

      <tbody class="divide-y">
      <% @products.each do |product| %>
        <tr class="hover:bg-gray-50">
          <td class="p-3">
            <div class="font-semibold text-gray-900"><%= product.name %></div>
          </td>

          <td class="p-3">
            <span class="font-mono text-sm text-gray-700"><%= product.sku %></span>
          </td>

          <td class="p-3 font-semibold">
            <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
          </td>
          <td class="p-3">
            <% if product.stock_quantity.to_i <= 0 %>
    <span class="inline-flex items-center px-2 py-1 text-xs font-bold rounded bg-red-100 text-red-800">
      0
    </span>
            <% else %>
              <span class="font-semibold"><%= product.stock_quantity %></span>
            <% end %>
          </td>

          <td class="p-3">
            <% if product.active? %>
                <span class="inline-flex items-center px-2 py-1 text-xs font-bold rounded bg-green-100 text-green-800">
                  AKTIVAN
                </span>
            <% else %>
                <span class="inline-flex items-center px-2 py-1 text-xs font-bold rounded bg-gray-200 text-gray-700">
                  NEAKTIVAN
                </span>
            <% end %>
          </td>

          <td class="p-3">
            <div class="flex justify-end gap-2">
              <%= link_to "Uredi", edit_admin_product_path(product), class: btn_secondary %>

              <%= button_to "Obriši",
                            admin_product_path(product),
                            method: :delete,
                            data: { turbo_confirm: "Jesi siguran?" },
                            class: btn_danger %>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @products.blank? %>
        <tr>
          <td colspan="6" class="p-6 text-center text-gray-600">
            Nema proizvoda. Klikni <strong>Novi proizvod</strong> da dodaš prvi.
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
<div class="mt-6 flex justify-center">
  <%= paginate @products %>
</div>