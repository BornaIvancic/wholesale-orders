<div class="max-w-6xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Partneri</h1>
      <p class="text-sm text-gray-600 mt-1">
        Pregled i uređivanje rabata, rokova plaćanja i e-pošte za ponude.
      </p>
    </div>

    <%= link_to "Novi partner",
                new_admin_company_path,
                class: "px-4 py-2 bg-blue-600 text-white rounded-lg shadow hover:bg-blue-700 transition" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Naziv</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Rabat</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Rok plaćanja</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">E-pošta za ponude</th>
          <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Akcije</th>
        </tr>
        </thead>

        <tbody class="divide-y divide-gray-100">
        <% @companies.each do |c| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <div class="font-medium text-gray-900"><%= c.name %></div>
            </td>

            <td class="px-4 py-3 text-sm text-gray-700 whitespace-nowrap">
                <span class="inline-flex items-center rounded-full bg-blue-50 text-blue-700 px-2 py-0.5 text-xs font-semibold">
                  <%= c.discount_percent %>%
                </span>
            </td>

            <td class="px-4 py-3 text-sm text-gray-700 whitespace-nowrap">
                <span class="inline-flex items-center rounded-full bg-gray-100 text-gray-700 px-2 py-0.5 text-xs font-semibold">
                  <%= c.payment_terms_days %> dana
                </span>
            </td>

            <td class="px-4 py-3 text-sm text-gray-700">
              <% if c.offers_email.present? %>
                <span class="break-all"><%= c.offers_email %></span>
              <% else %>
                <span class="text-gray-400 italic">Nije postavljeno</span>
              <% end %>
            </td>

            <td class="px-4 py-3 text-right whitespace-nowrap">
              <%= link_to "Uredi",
                          edit_admin_company_path(c),
                          class: "inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-sm font-semibold text-gray-700 hover:bg-gray-50" %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>

    <% if @companies.blank? %>
      <div class="p-6 text-sm text-gray-600">
        Nema partnera za prikaz.
      </div>
    <% end %>
  </div>
</div>

<div class="mt-6 flex justify-center">
  <%= paginate @companies %>
</div>