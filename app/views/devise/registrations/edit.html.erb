<div class="min-h-[80vh] flex items-center justify-center">
  <div class="w-full max-w-lg bg-white shadow-lg rounded-2xl p-8 border">

    <h1 class="text-2xl font-bold mb-2 text-gray-900">
      Uredi profil
    </h1>

    <p class="text-gray-600 mb-6">
      Ažuriraj svoje podatke za WineHub račun.
    </p>

    <%= form_for(resource,
                 as: resource_name,
                 url: registration_path(resource_name),
                 html: { method: :put, class: "space-y-5" }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- Email -->
      <div>
        <%= f.label :email, "Email", class: "block text-sm font-semibold mb-1" %>
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="text-sm text-yellow-600 bg-yellow-50 border border-yellow-200 rounded p-3">
          Čeka se potvrda za: <strong><%= resource.unconfirmed_email %></strong>
        </div>
      <% end %>

      <!-- Nova lozinka -->
      <div>
        <%= f.label :password, "Nova lozinka",
                    class: "block text-sm font-semibold mb-1" %>
        <p class="text-xs text-gray-500 mb-1">
          Ostavi prazno ako ne želiš mijenjati lozinku.
        </p>
        <%= f.password_field :password,
                             autocomplete: "new-password",
                             class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>

        <% if @minimum_password_length %>
          <p class="text-xs text-gray-400 mt-1">
            Minimum <%= @minimum_password_length %> znakova
          </p>
        <% end %>
      </div>

      <!-- Potvrda lozinke -->
      <div>
        <%= f.label :password_confirmation, "Potvrdi novu lozinku",
                    class: "block text-sm font-semibold mb-1" %>
        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <!-- Trenutna lozinka -->
      <div>
        <%= f.label :current_password, "Trenutna lozinka",
                    class: "block text-sm font-semibold mb-1" %>
        <p class="text-xs text-gray-500 mb-1">
          Potrebna je za potvrdu promjena.
        </p>
        <%= f.password_field :current_password,
                             autocomplete: "current-password",
                             class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <!-- Submit -->
      <div>
        <%= f.submit "Spremi promjene",
                     class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition shadow" %>
      </div>

    <% end %>

    <!-- Cancel account -->
    <div class="mt-8 border-t pt-6">
      <h3 class="text-lg font-semibold text-red-600 mb-3">
        Obriši račun
      </h3>

      <%= button_to "Obriši moj račun",
                    registration_path(resource_name),
                    method: :delete,
                    data: { turbo_confirm: "Jesi siguran da želiš obrisati račun?" },
                    class: "w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 rounded-lg transition shadow" %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to "← Natrag", root_path,
                  class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>

  </div>
</div>