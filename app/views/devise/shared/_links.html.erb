<div class="mt-6 space-y-2 text-sm">
  <%- if controller_name != "sessions" %>
    <%= link_to "Prijava",
                new_session_path(resource_name),
                class: "block text-gray-700 hover:text-gray-900 underline underline-offset-4" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "Registracija",
                new_registration_path(resource_name),
                class: "block text-gray-700 hover:text-gray-900 underline underline-offset-4" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <%= link_to "Zaboravljena lozinka?",
                new_password_path(resource_name),
                class: "block text-gray-700 hover:text-gray-900 underline underline-offset-4" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <%= link_to "Nisi dobio potvrdu e-maila?",
                new_confirmation_path(resource_name),
                class: "block text-gray-700 hover:text-gray-900 underline underline-offset-4" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <%= link_to "Nisi dobio upute za otključavanje?",
                new_unlock_path(resource_name),
                class: "block text-gray-700 hover:text-gray-900 underline underline-offset-4" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <div class="pt-2 space-y-2">
      <%- resource_class.omniauth_providers.each do |provider| %>
        <%= button_to "Prijava preko #{OmniAuth::Utils.camelize(provider)}",
                      omniauth_authorize_path(resource_name, provider),
                      class: "w-full px-4 py-2 rounded bg-gray-900 text-white font-semibold hover:bg-gray-800 transition" %>
      <% end %>
    </div>
  <% end %>
</div>