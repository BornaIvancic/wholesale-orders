<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md bg-white shadow-lg rounded-2xl p-8 border">

    <h1 class="text-2xl font-bold mb-2 text-gray-900">
      WineHub
    </h1>

    <p class="text-gray-600 mb-6">
      Promijeni lozinku
    </p>

    <%= form_for(resource,
                 as: resource_name,
                 url: password_path(resource_name),
                 html: { method: :put, class: "space-y-5" }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div>
        <%= f.label :password, "Nova lozinka", class: "block text-sm font-semibold mb-1" %>

        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mb-2">
            Minimalno <%= @minimum_password_length %> znakova
          </p>
        <% end %>

        <%= f.password_field :password,
                             autofocus: true,
                             autocomplete: "new-password",
                             class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Potvrdi lozinku", class: "block text-sm font-semibold mb-1" %>

        <%= f.password_field :password_confirmation,
                             autocomplete: "new-password",
                             class: "w-full border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.submit "Promijeni lozinku",
                     class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition shadow" %>
      </div>

    <% end %>

    <div class="mt-6 text-sm text-gray-500 text-center">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>