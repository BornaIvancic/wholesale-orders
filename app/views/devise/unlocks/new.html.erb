<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md bg-white p-8 rounded-xl shadow-sm border">

    <h2 class="text-2xl font-bold mb-6 text-center">
      Otključavanje računa
    </h2>

    <%= form_for(resource,
                 as: resource_name,
                 url: unlock_path(resource_name),
                 html: { method: :post, class: "space-y-5" }) do |f| %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, "Email", class: "block text-sm font-semibold mb-2" %>
        <%= f.email_field :email,
                          autofocus: true,
                          autocomplete: "email",
                          class: "w-full border rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= f.submit "Pošalji upute za otključavanje",
                     class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded transition" %>
      </div>

    <% end %>

    <%= render "devise/shared/links" %>

  </div>
</div>