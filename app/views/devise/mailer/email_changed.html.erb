<div style="font-family: Arial, sans-serif; background-color: #f9fafb; padding: 40px 20px;">
  <div style="max-width: 520px; margin: 0 auto; background: #ffffff; border-radius: 12px; padding: 32px; border: 1px solid #e5e7eb;">

    <h1 style="margin: 0 0 16px 0; font-size: 22px; font-weight: bold; color: #111827;">
      WineHub – Email Update
    </h1>

    <p style="color: #374151; font-size: 15px; margin-bottom: 24px;">
      Hello <strong><%= @email %></strong>,
    </p>

    <% if @resource.try(:unconfirmed_email?) %>
      <p style="color: #374151; font-size: 15px; margin-bottom: 16px;">
        Your account email is being changed to:
      </p>

      <p style="font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 24px;">
        <%= @resource.unconfirmed_email %>
      </p>

      <p style="color: #6b7280; font-size: 14px;">
        Please confirm the new email address to complete the change.
      </p>
    <% else %>
      <p style="color: #374151; font-size: 15px; margin-bottom: 16px;">
        Your account email has been successfully updated to:
      </p>

      <p style="font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 24px;">
        <%= @resource.email %>
      </p>
    <% end %>

    <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 24px 0;">

    <p style="font-size: 13px; color: #6b7280; line-height: 1.6;">
      If you did not request this change, please contact support immediately.
    </p>

    <p style="font-size: 12px; color: #9ca3af; text-align: center; margin-top: 24px;">
      © <%= Time.current.year %> WineHub
    </p>

  </div>
</div>