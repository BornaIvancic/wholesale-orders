<div class="max-w-2xl mx-auto">
  <div class="bg-white shadow rounded-lg p-8">

    <h1 class="text-2xl font-bold mb-6">Moj profil</h1>

    <div class="space-y-4 text-sm">

      <div class="flex justify-between border-b pb-2">
        <span class="text-gray-600">Email</span>
        <span class="font-medium text-gray-900"><%= current_user.email %></span>
      </div>

      <div class="flex justify-between border-b pb-2">
        <span class="text-gray-600">Uloga</span>
        <span class="font-medium text-gray-900">
          <%= current_user.admin? ? "Administrator" : "Partner" %>
        </span>
      </div>

      <% if current_user.partner_user? %>
        <div class="flex justify-between border-b pb-2">
          <span class="text-gray-600">Firma</span>
          <span class="font-medium text-gray-900">
            <%= current_user.company&.name %>
          </span>
        </div>
      <% end %>

    </div>

    <div class="mt-8 flex gap-3">
      <%= link_to "Uredi podatke",
                  edit_user_registration_path,
                  class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold" %>

      <%= link_to "Promijeni lozinku",
                  edit_user_registration_path,
                  class: "px-4 py-2 bg-gray-200 hover:bg-gray-300 rounded font-semibold" %>
    </div>

  </div>
</div>